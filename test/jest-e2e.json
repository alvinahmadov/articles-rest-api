{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "maxWorkers": 1,
  "forceExit": true,
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@common/(.*)$": "<rootDir>/../src/common/$1",
    "^@api/(.*)$": "<rootDir>/../src/api/$1",
    "^@database/(.*)$": "<rootDir>/../src/common/database/$1",
    "^@domain/(.*)$": "<rootDir>/../src/domain/$1"
  }
}
